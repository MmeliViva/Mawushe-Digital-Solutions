<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Mawushe Digital Solutions</title>

  <style>
    body {
      margin: 0;
      font-family: Arial, sans-serif;
    }

    header {
      background: #0d3b66;
      color: white;
      padding: 15px 40px;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    header nav a {
      color: white;
      margin: 0 10px;
      text-decoration: none;
    }

    .btn {
      background: #1d6fa5;
      padding: 10px 15px;
      border-radius: 5px;
      color: white;
      text-decoration: none;
    }

    .hero {
      background: linear-gradient(to right, #0d3b66, #1d6fa5);
      color: white;
      padding: 80px 40px;
      display: flex;
      justify-content: space-between;
      flex-wrap: wrap;
    }

    .hero h1 {
      font-size: 40px;
    }

    .section {
      padding: 50px 40px;
      text-align: center;
    }

    .cards {
      display: flex;
      gap: 20px;
      justify-content: center;
      flex-wrap: wrap;
      margin-top: 30px;
    }

    .card {
      background: #0d3b66;
      color: white;
      padding: 20px;
      width: 220px;
      border-radius: 5px;
    }

    .light-card {
      background: #f1f1f1;
      color: black;
    }

    footer {
      background: #0d3b66;
      color: white;
      padding: 30px;
      text-align: center;
    }

    input, textarea {
      width: 100%;
      padding: 10px;
      margin: 5px 0;
    }

  </style>
</head>

<body>

<!-- HEADER -->
<header>
  <h2>Mawushe Digital Solutions</h2>
  <nav>
    <a href="#">Home</a>
    <a href="#">Services</a>
    <a href="#">About</a>
    <a href="#">Blog</a>
    <a href="#">Contact</a>
    <a href="#" class="btn">Get a Quote</a>
  </nav>
</header>

<!-- HERO -->
<section class="hero">
  <div>
    <h1>Empowering Your Business with Microsoft 365 & IT Solutions</h1>
    <p>Affordable Cloud Services & IT Support for African Businesses.</p>
    <a href="#" class="btn">Get Started</a>
    <a href="#" class="btn">Learn More</a>
  </div>
</section>

<!-- SERVICES -->
<section class="section">
  <h2>Our Key Services</h2>
  <div class="cards">
    <div class="card">Microsoft 365 Solutions</div>
    <div class="card">Cloud Backup & Security</div>
    <div class="card">Managed IT Services</div>
    <div class="card">Email & Migration</div>
  </div>
</section>

<!-- WHY US -->
<section class="section">
  <h2>Why Choose Us?</h2>
  <div class="cards">
    <div class="card light-card">
      <h4>Expertise in Microsoft 365</h4>
      <p>Professional support and cloud solutions.</p>
    </div>

    <div class="card light-card">
      <h4>Local & Reliable Support</h4>
      <p>Fast support team based in South Africa.</p>
    </div>

    <div class="card light-card">
      <h4>Tailored IT Solutions</h4>
      <p>Custom solutions for your business growth.</p>
    </div>
  </div>
</section>

<!-- ABOUT -->
<section class="hero">
  <div>
    <h2>About Mawushe Digital Solutions</h2>
    <p>
      Driven to empower African businesses with cutting-edge technology and dedicated support.
    </p>
    <a href="#" class="btn">Learn More</a>
  </div>
</section>

<!-- ICT TRAINING -->
<section class="section">
  <h2>ICT Training Programs</h2>
  <div class="cards">
    <div class="card">Microsoft 365 Training</div>
    <div class="card">Cybersecurity Training</div>
    <div class="card">Cloud Computing</div>
    <div class="card">IT Support Training</div>
    <div class="card">Digital Skills</div>
  </div>
</section>

<!-- CLIENTS -->
<section class="section">
  <h2>Our Clients</h2>
  <p>Client logos will appear here</p>
</section>

<!-- TESTIMONIALS -->
<section class="section">
  <h2>Success Stories</h2>
  <div class="cards">
    <div class="card light-card">
      <p>"Great IT support team!"</p>
      <small>- John D., Cape Town</small>
    </div>

    <div class="card light-card">
      <p>"Seamless Microsoft 365 migration."</p>
      <small>- Susan M., Johannesburg</small>
    </div>
  </div>
</section>

<!-- BLOG -->
<section class="section">
  <h2>Latest Insights</h2>
  <div class="cards">
    <div class="card light-card">How to Secure Microsoft 365</div>
    <div class="card light-card">Cloud Backup for SMEs</div>
    <div class="card light-card">Remote Work with Teams</div>
  </div>
</section>

<!-- CONTACT -->
<section class="section">
  <h2>Get in Touch</h2>

  <form>
    <input type="text" placeholder="Your Name" required>
    <input type="email" placeholder="Email Address" required>
    <input type="text" placeholder="Phone Number">
    <textarea placeholder="Your Message"></textarea>
    <button class="btn">Send Message</button>
  </form>

</section>

<!-- FOOTER -->
<footer>
  <p>© 2026 Mawushe Digital Solutions. All Rights Reserved.</p>
</footer>

</body>
</html>

  <div class="container position-relative">
    <div class="row align-items-center g-4">
      <!---- Left: Glass card with content-->
      <div class="col-lg-8" data-aos="fade-up">